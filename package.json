{
    "name": "dynamic-captions",
    "version": "1.0.2",
    "description": "Face-Tracking Captions Chrome Extension",
    "scripts": {
        "build": "esbuild src/index.js --bundle --outfile=dist/content.js",
        "watch": "esbuild src/index.js --bundle --outfile=dist/content.js --watch",
        "package": "npm run build && node scripts/package.js",
        "bump": "node scripts/version.js"
    },
    "devDependencies": {
        "esbuild": "^0.27.3"
    }
}